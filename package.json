{
  "name": "overframe",
  "version": "0.1.1",
  "description": "A lightweight, non-intrusive web overlay browser for gamers.",
  "main": "out/main/index.js",
  "author": "Overframe",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/overframeApp-arch/Overframe"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "pnpm build && electron-forge package",
    "make": "pnpm build && electron-forge make",
    "publish": "pnpm build && electron-forge publish",
    "typecheck:node": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.web.json",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "lint": "node node_modules/eslint/bin/eslint.js src --ext .ts,.tsx",
    "check": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen-assets": "node scripts/gen-assets.mjs",
    "gen-loading-gif": "node scripts/gen-loading-gif.mjs",
    "check:deps": "node scripts/check-dangerous-deps.mjs",
    "landing": "pnpm --filter overframe-landing dev",
    "landing:build": "pnpm --filter overframe-landing build",
    "landing:start": "pnpm --filter overframe-landing start"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "base64-js": "^1.5.1",
    "better-sqlite3": "^12.0.0",
    "electron-store": "^8.2.0",
    "koffi": "^3.0.0",
    "ps-list": "^7.2.0",
    "uiohook-napi": "^1.5.5",
    "update-electron-app": "^3.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.5.0",
    "@eslint/js": "^9.39.4",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^33.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "lucide-react": "^0.451.0",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.9",
    "zustand": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "uiohook-napi"
    ],
    "overrides": {
      "tar": ">=7.5.11"
    }
  }
}
